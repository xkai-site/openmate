{
  "name": "aitq-frontend",
  "private": true,
  "version": "0.0.1",
  "description": "OpenMate frontend and Electron desktop shell",
  "author": "OpenMate Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:start": "electron electron/main.cjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.68.0",
    "antd": "^5.25.0",
    "axios": "^1.8.2",
    "dagre": "^0.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.6"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.13.8",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.1.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.openmate.desktop",
    "productName": "OpenMate",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "dir"
      ]
    }
  }
}
